---
// src/components/Hero.astro
export interface Props {
  name: string;
  role: string;
  pitch: string;
}
const { name, role, pitch } = Astro.props;
---
<section class="hero" id="top">
  <div class="eyebrow">Available for opportunities</div>
  <h1 class="name">{name}</h1>
  <p class="role">{role}</p>
  <p class="pitch">{pitch}</p>
  <div class="hero-links">
    <a class="btn primary" href="#contact">get in touch</a>
    <a class="btn" href="#projects">view projects</a>
    <a class="btn" href="/resume.pdf" target="_blank" rel="noopener">résumé.pdf</a>
  </div>

  <div class="diagram-wrap">
    <svg class="sysdiagram" viewBox="0 0 860 260" width="100%" role="img" aria-label="System diagram connecting Jordan to Backend Systems, Applied ML, Research and Teaching">
      <path d="M 430 130 H 200 V 40" />
      <path d="M 430 130 H 660 V 40" />
      <path d="M 430 130 H 200 V 220" />
      <path d="M 430 130 H 660 V 220" />
      <path class="pulse" d="M 430 130 H 200 V 40" />
      <path class="pulse" d="M 430 130 H 660 V 220" />
      <rect class="node center" x="368" y="106" width="124" height="48" />
      <text class="center-label" x="430" y="135" font-size="13" text-anchor="middle">{name.toUpperCase()}</text>
      <rect class="node" x="120" y="12" width="160" height="46" />
      <text x="200" y="31" font-size="11" text-anchor="middle">BACKEND SYSTEMS</text>
      <text x="200" y="47" font-size="9.5" text-anchor="middle" opacity="0.7">FastAPI · PostgreSQL · AWS</text>
      <rect class="node" x="580" y="12" width="160" height="46" />
      <text x="660" y="31" font-size="11" text-anchor="middle">APPLIED ML</text>
      <text x="660" y="47" font-size="9.5" text-anchor="middle" opacity="0.7">PyTorch · scikit-learn</text>
      <rect class="node" x="120" y="196" width="160" height="46" />
      <text x="200" y="215" font-size="11" text-anchor="middle">RESEARCH</text>
      <text x="200" y="231" font-size="9.5" text-anchor="middle" opacity="0.7">IEEE LA-CCI '21</text>
      <rect class="node" x="580" y="196" width="160" height="46" />
      <text x="660" y="215" font-size="11" text-anchor="middle">TEACHING</text>
      <text x="660" y="231" font-size="9.5" text-anchor="middle" opacity="0.7">Multi-institution</text>
    </svg>
    <div class="diagram-caption">
      <span>FIG. 1: SYSTEM CONTEXT</span>
      <span>C4-STYLE / L1</span>
    </div>
  </div>
</section>